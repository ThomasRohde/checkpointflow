{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/checkpointflow-run-envelope.schema.json",
  "title": "checkpointflow run envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ok",
    "command",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "checkpointflow-run/v1"
    },
    "request_id": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "command": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "running",
        "waiting",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "exit_code": {
      "type": "integer"
    },
    "run_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "workflow_version": {
      "type": "string"
    },
    "current_step_id": {
      "type": "string"
    },
    "checkpoint_id": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "result": {},
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "step_id": {
          "type": "string"
        },
        "details": {}
      }
    },
    "wait": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "audience",
        "event_name",
        "input_schema",
        "resume"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "external_event"
        },
        "audience": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "system"
          ]
        },
        "event_name": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "input_schema": {
          "type": "object"
        },
        "instructions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeout_at": {
          "type": "string"
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "resume": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "command"
          ],
          "properties": {
            "command": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "waiting"
          }
        }
      },
      "then": {
        "required": [
          "wait",
          "run_id"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "ok": {
            "const": false
          }
        }
      },
      "then": {
        "required": [
          "error"
        ]
      }
    }
  ]
}
